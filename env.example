# ====================================
# CONFIGURAÇÕES DO ANALISADOR ESPORTIVO
# ====================================

# MODELO OLLAMA
# Recomendado: llama3.1:8b (melhor custo-benefício)
# Alternativas: qwen2.5:14b, mistral:7b, llama3.1:70b
OLLAMA_MODEL=llama3.1:8b

# URL DO OLLAMA (padrão: localhost)
OLLAMA_URL=http://localhost:11434/api/chat

# ====================================
# PARÂMETROS AVANÇADOS (Opcional)
# ====================================

# Diretório das ligas (padrão: leagues)
# LEAGUES_DIR=leagues

# Fator de decaimento temporal (padrão: 0.88)
# Quanto menor, mais peso nos jogos recentes
# Valores recomendados: 0.85 (muito recente) a 0.92 (mais histórico)
# DECAY_FACTOR=0.88

# Vantagem de jogar em casa em gols (padrão: 0.35)
# Valores típicos: 0.25 (ligas equilibradas) a 0.45 (forte vantagem casa)
# HOME_ADV_GOALS=0.35

# Quantos jogos focar para forma recente (padrão: 5)
# RECENT_GAMES_FOCUS=5

# Total de jogos para análise estatística (padrão: 12)
# TOTAL_GAMES_ANALYSIS=12

# ====================================
# NOTAS IMPORTANTES
# ====================================

# 1. Para instalar o modelo recomendado:
#    ollama pull llama3.1:8b

# 2. Certifique-se de que o Ollama está rodando:
#    ollama serve

# 3. Estrutura de diretórios esperada:
#    projeto/
#    ├── .env (este arquivo)
#    ├── analise_esportiva_melhorado.py
#    └── leagues/
#        ├── ligue-1-2025-UTC.csv
#        ├── epl-2025-GMTStandardTime.csv
#        ├── la-liga-2025-UTC.csv
#        └── bundesliga-2025-UTC.csv

# 4. Formato esperado dos CSVs:
#    Colunas: DATE, HOME TEAM, AWAY TEAM, RESULT
#    Exemplo RESULT: "2-1" ou vazio para jogos futuros
